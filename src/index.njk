{# ========== STORY ========== #}
<section id="story" class="py-24 bg-cream relative overflow-hidden">
  <div class="absolute top-0 right-0 w-64 h-64 bg-gold/5 rounded-full blur-3xl"></div>
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid md:grid-cols-2 gap-16 items-center">
      <div class="fade-up">
        <p class="text-terracotta text-sm tracking-[0.3em] uppercase mb-4 font-medium">Our Story</p>
        <h2 class="font-display text-4xl md:text-5xl font-bold text-charcoal mb-8 leading-tight">
          Where the Mediterranean<br>
          <span class="text-olive">Meets Miami</span>
        </h2>
        <p class="text-charcoal-light leading-relaxed mb-6">
          Since 2015, Safron Mediterranean Grill has been bringing the authentic flavors of Turkish and Mediterranean cuisine to the vibrant streets of Miami Beach. Every dish is crafted with passion, using traditional recipes passed down through generations.
        </p>
        <p class="text-charcoal-light leading-relaxed">
          From our hand-seasoned Adana kebabs to our perfectly crispy falafel, every bite tells a story of the Mediterranean. We offer vegetarian and vegan options so everyone can enjoy the richness of our culinary heritage.
        </p>
      </div>
      <div class="fade-up grid grid-cols-2 gap-4">
        <div class="warm-card rounded-2xl p-8 text-center">
          <p class="text-4xl font-display font-bold text-terracotta">10+</p>
          <p class="text-charcoal-light text-sm mt-2">Years Serving</p>
        </div>
        <div class="warm-card rounded-2xl p-8 text-center">
          <p class="text-4xl font-display font-bold text-olive">900+</p>
          <p class="text-charcoal-light text-sm mt-2">Yelp Reviews</p>
        </div>
        <div class="warm-card rounded-2xl p-8 text-center">
          <p class="text-4xl font-display font-bold text-spice">100%</p>
          <p class="text-charcoal-light text-sm mt-2">Halal Meat</p>
        </div>
        <div class="warm-card rounded-2xl p-8 text-center">
          <p class="text-4xl font-display font-bold text-terracotta">&#9829;</p>
          <p class="text-charcoal-light text-sm mt-2">Made with Love</p>
        </div>
      </div>
    </div>
  </div>
</section>

{# ========== MENU ========== #}
<section id="menu" class="py-24 bg-warm-white relative">
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center mb-16 fade-up">
      <p class="text-terracotta text-sm tracking-[0.3em] uppercase mb-4 font-medium">The Menu</p>
      <h2 class="font-display text-4xl md:text-5xl font-bold text-charcoal">Taste the <span class="text-terracotta">Mediterranean</span></h2>
      <p class="text-charcoal-light mt-4 max-w-lg mx-auto">Authentic flavors crafted with traditional recipes. All kebab platters include side salad, rice, pita bread & tzatziki.</p>
    </div>

    {# Kebab Platters #}
    <div class="mb-16 fade-up">
      <h3 class="divider-ornament font-display text-2xl font-bold text-gold mb-8">Kebab Platters</h3>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {% set platters = [
          { name: "Adana Kebab", desc: "Hand-minced lamb seasoned with Urfa pepper & herbs, charcoal grilled", price: "$19.99" },
          { name: "Lamb Shish Kebab", desc: "Tender cubes of marinated lamb, grilled to perfection on skewers", price: "$22.00" },
          { name: "Chicken Kebab", desc: "Juicy chicken breast marinated in Mediterranean spices", price: "$18.99" },
          { name: "Kofte Kebab", desc: "Traditional Turkish meatballs with aromatic herbs & spices", price: "$19.99" },
          { name: "Doner Gyro", desc: "Slow-cooked rotisserie meat, thinly sliced & perfectly seasoned", price: "$18.99" },
          { name: "Falafel Platter", desc: "Crispy golden chickpea fritters with fresh herbs — 100% vegan", price: "$16.95" }
        ] %}
        {% for item in platters %}
        <div class="menu-card rounded-2xl p-6">
          <div class="flex justify-between items-start mb-3">
            <h4 class="font-display text-lg font-semibold text-charcoal">{{ item.name }}</h4>
            <span class="text-terracotta font-semibold whitespace-nowrap ml-4">{{ item.price }}</span>
          </div>
          <p class="text-charcoal-light text-sm leading-relaxed">{{ item.desc }}</p>
        </div>
        {% endfor %}
      </div>
    </div>

    {# Wraps #}
    <div class="mb-16 fade-up">
      <h3 class="divider-ornament font-display text-2xl font-bold text-gold mb-8">Wraps</h3>
      <div class="grid md:grid-cols-3 gap-6">
        {% set wraps = [
          { name: "Chicken Wrap", desc: "Grilled chicken with fresh veggies, wrapped in warm lavash", price: "$9.99" },
          { name: "Gyro Wrap", desc: "Sliced doner meat with lettuce, tomato, onion & tzatziki", price: "$9.99" },
          { name: "Falafel Wrap", desc: "Crispy falafel with hummus, pickles & tahini — vegan friendly", price: "$9.99" }
        ] %}
        {% for item in wraps %}
        <div class="menu-card rounded-2xl p-6">
          <div class="flex justify-between items-start mb-3">
            <h4 class="font-display text-lg font-semibold text-charcoal">{{ item.name }}</h4>
            <span class="text-terracotta font-semibold">{{ item.price }}</span>
          </div>
          <p class="text-charcoal-light text-sm leading-relaxed">{{ item.desc }}</p>
        </div>
        {% endfor %}
      </div>
    </div>

    {# Appetizers & Salads #}
    <div class="mb-16 fade-up">
      <h3 class="divider-ornament font-display text-2xl font-bold text-gold mb-8">Appetizers & Salads</h3>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {% set sides = [
          { name: "Hummus", desc: "Creamy chickpea dip with tahini, lemon & olive oil", price: "$9.99" },
          { name: "Baba Ganoush", desc: "Smoky roasted eggplant blended with garlic & tahini", price: "$9.99" },
          { name: "Tzatziki", desc: "Cool yogurt dip with cucumber, garlic & fresh dill", price: "$9.99" },
          { name: "Lentil Soup", desc: "Traditional Turkish red lentil soup with a squeeze of lemon", price: "$8.50" },
          { name: "Greek Salad", desc: "Crisp greens, feta, olives, cucumber & tomato", price: "$14.99" },
          { name: "Shepherd Salad", desc: "Finely diced tomato, cucumber, onion & parsley with lemon", price: "$15.99" }
        ] %}
        {% for item in sides %}
        <div class="menu-card rounded-2xl p-6">
          <div class="flex justify-between items-start mb-3">
            <h4 class="font-display text-lg font-semibold text-charcoal">{{ item.name }}</h4>
            <span class="text-terracotta font-semibold">{{ item.price }}</span>
          </div>
          <p class="text-charcoal-light text-sm leading-relaxed">{{ item.desc }}</p>
        </div>
        {% endfor %}
      </div>
    </div>

    {# Dessert #}
    <div class="fade-up">
      <h3 class="divider-ornament font-display text-2xl font-bold text-gold mb-8">Dessert</h3>
      <div class="max-w-sm">
        <div class="menu-card rounded-2xl p-6">
          <div class="flex justify-between items-start mb-3">
            <h4 class="font-display text-lg font-semibold text-charcoal">Baklava (4 pcs)</h4>
            <span class="text-terracotta font-semibold">$9.00</span>
          </div>
          <p class="text-charcoal-light text-sm leading-relaxed">Layers of flaky phyllo pastry, crushed pistachios & sweet honey syrup</p>
        </div>
      </div>
    </div>
  </div>
</section>

