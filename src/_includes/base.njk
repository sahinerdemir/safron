<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} | Safron Mediterranean Grill</title>
  <meta name="description" content="{{ description or 'Authentic Turkish and Mediterranean cuisine in the heart of Miami Beach. Established 2015.' }}">
  <meta property="og:title" content="{{ title }} | Safron Mediterranean Grill">
  <meta property="og:description" content="{{ description or 'Authentic Turkish and Mediterranean cuisine in the heart of Miami Beach.' }}">
  <meta property="og:type" content="website">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/output.css">
</head>
<body class="bg-warm-white text-charcoal font-body">
  {{ content | safe }}

  <script>
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
        }
      });
    }, { threshold: 0.1 });
    document.querySelectorAll('.fade-up').forEach(el => observer.observe(el));

    // Deel-style transform slider
    class Slider {
      constructor(id) {
        this.container = document.querySelector(`[data-slider="${id}"]`);
        if (!this.container) return;
        this.track = this.container.querySelector('.slider-track');
        this.cards = [...this.track.children];
        this.prevBtn = document.querySelector(`[data-prev="${id}"]`);
        this.nextBtn = document.querySelector(`[data-next="${id}"]`);
        this.index = 0;
        this.dragStartX = 0;
        this.dragOffset = 0;
        this.isDragging = false;

        this.prevBtn?.addEventListener('click', () => this.prev());
        this.nextBtn?.addEventListener('click', () => this.next());

        this.track.addEventListener('mousedown', e => this.onDragStart(e));
        this.track.addEventListener('touchstart', e => this.onDragStart(e), { passive: true });
        window.addEventListener('mousemove', e => this.onDragMove(e));
        window.addEventListener('touchmove', e => this.onDragMove(e), { passive: false });
        window.addEventListener('mouseup', () => this.onDragEnd());
        window.addEventListener('touchend', () => this.onDragEnd());

        window.addEventListener('resize', () => this.goTo(this.index));
        this.updateButtons();
      }
      getCardWidth() {
        if (!this.cards.length) return 0;
        const style = getComputedStyle(this.track);
        const gap = parseFloat(style.gap) || 20;
        return this.cards[0].offsetWidth + gap;
      }
      getVisibleWidth() {
        const containerLeft = this.container.getBoundingClientRect().left;
        const paddingLeft = parseFloat(getComputedStyle(this.container).paddingLeft) || 0;
        return window.innerWidth - containerLeft - paddingLeft;
      }
      getMaxOffset() {
        const gap = parseFloat(getComputedStyle(this.track).gap) || 20;
        const totalW = this.cards.length * this.getCardWidth() - gap;
        return Math.max(0, totalW - this.getVisibleWidth());
      }
      getMaxIndex() {
        return Math.max(0, Math.ceil(this.getMaxOffset() / this.getCardWidth()));
      }
      goTo(i) {
        this.index = Math.max(0, Math.min(i, this.getMaxIndex()));
        const offset = this.index >= this.getMaxIndex()
          ? this.getMaxOffset()
          : this.index * this.getCardWidth();
        this.track.style.transform = `translateX(-${offset}px)`;
        this.updateButtons();
      }
      prev() { this.goTo(this.index - 1); }
      next() { this.goTo(this.index + 1); }
      updateButtons() {
        if (this.prevBtn) this.prevBtn.disabled = this.index <= 0;
        if (this.nextBtn) this.nextBtn.disabled = this.index >= this.getMaxIndex();
      }
      onDragStart(e) {
        this.isDragging = true;
        this.dragStartX = e.type === 'touchstart' ? e.touches[0].clientX : e.clientX;
        this.dragOffset = 0;
        this.track.classList.add('is-dragging');
      }
      onDragMove(e) {
        if (!this.isDragging) return;
        const x = e.type === 'touchmove' ? e.touches[0].clientX : e.clientX;
        this.dragOffset = x - this.dragStartX;
        const base = this.index >= this.getMaxIndex()
          ? this.getMaxOffset()
          : this.index * this.getCardWidth();
        this.track.style.transform = `translateX(${-base + this.dragOffset}px)`;
      }
      onDragEnd() {
        if (!this.isDragging) return;
        this.isDragging = false;
        this.track.classList.remove('is-dragging');
        const threshold = this.getCardWidth() * 0.25;
        if (this.dragOffset < -threshold) this.next();
        else if (this.dragOffset > threshold) this.prev();
        else this.goTo(this.index);
      }
    }

    document.querySelectorAll('[data-slider]').forEach(el => {
      new Slider(el.dataset.slider);
    });

    // Nav scroll behavior — transparent on hero, solid on scroll
    const nav = document.getElementById('main-nav');
    const navCta = document.getElementById('nav-cta');
    function updateNav() {
      const scrolled = window.scrollY > 80;
      if (scrolled) {
        nav.classList.add('bg-warm-white/95', 'backdrop-blur-md', 'shadow-sm');
        nav.classList.remove('bg-transparent');
        nav.querySelectorAll('.nav-logo-primary').forEach(el => { el.classList.remove('text-white'); el.classList.add('text-terracotta'); });
        nav.querySelectorAll('.nav-logo-secondary').forEach(el => { el.classList.remove('text-white/80'); el.classList.add('text-charcoal'); });
        nav.querySelectorAll('.nav-link').forEach(el => { el.classList.remove('text-white/80', 'hover:text-white'); el.classList.add('text-charcoal-light', 'hover:text-terracotta'); });
        nav.querySelectorAll('.nav-mobile-link').forEach(el => { el.classList.remove('text-white/80', 'hover:text-white'); el.classList.add('text-charcoal-light', 'hover:text-terracotta'); });
        nav.querySelectorAll('.nav-hamburger').forEach(el => { el.classList.remove('text-white'); el.classList.add('text-charcoal'); });
        if (navCta) { navCta.classList.remove('border-white/30', 'text-white', 'hover:bg-white/10'); navCta.classList.add('border-terracotta', 'text-terracotta', 'hover:bg-terracotta', 'hover:text-white'); }
      } else {
        nav.classList.remove('bg-warm-white/95', 'backdrop-blur-md', 'shadow-sm');
        nav.classList.add('bg-transparent');
        nav.querySelectorAll('.nav-logo-primary').forEach(el => { el.classList.add('text-white'); el.classList.remove('text-terracotta'); });
        nav.querySelectorAll('.nav-logo-secondary').forEach(el => { el.classList.add('text-white/80'); el.classList.remove('text-charcoal'); });
        nav.querySelectorAll('.nav-link').forEach(el => { el.classList.add('text-white/80', 'hover:text-white'); el.classList.remove('text-charcoal-light', 'hover:text-terracotta'); });
        nav.querySelectorAll('.nav-mobile-link').forEach(el => { el.classList.add('text-white/80', 'hover:text-white'); el.classList.remove('text-charcoal-light', 'hover:text-terracotta'); });
        nav.querySelectorAll('.nav-hamburger').forEach(el => { el.classList.add('text-white'); el.classList.remove('text-charcoal'); });
        if (navCta) { navCta.classList.add('border-white/30', 'text-white', 'hover:bg-white/10'); navCta.classList.remove('border-terracotta', 'text-terracotta', 'hover:bg-terracotta', 'hover:text-white'); }
      }
    }
    window.addEventListener('scroll', updateNav, { passive: true });
    updateNav();

    // Mobile menu toggle
    const menuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    if (menuBtn && mobileMenu) {
      menuBtn.addEventListener('click', () => {
        mobileMenu.classList.toggle('hidden');
      });
      mobileMenu.querySelectorAll('a').forEach(link => {
        link.addEventListener('click', () => mobileMenu.classList.add('hidden'));
      });
    }
  </script>
</body>
</html>
