{
  "name": "safron",
  "version": "1.0.0",
  "description": "Safron Mediterranean Grill - Miami Beach",
  "scripts": {
    "css": "npx @tailwindcss/cli -i src/css/input.css -o src/css/output.css --watch",
    "css:build": "npx @tailwindcss/cli -i src/css/input.css -o src/css/output.css --minify",
    "serve": "npx @11ty/eleventy --serve",
    "dev": "npm run css:build && (npm run css & npm run serve)",
    "build": "npm run css:build && npx @11ty/eleventy"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@11ty/eleventy": "^3.1.5",
    "@tailwindcss/cli": "^4.2.4",
    "tailwindcss": "^4.2.4"
  }
}
